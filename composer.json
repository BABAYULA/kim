{
    "name": "istanbul-airport-transfer/plugin",
    "description": "Istanbul Airport Transfer WordPress Plugin",
    "type": "wordpress-plugin",
    "version": "1.0.0",
    "license": "MIT",
    "authors": [
        {
            "name": "Istanbul Airport Transfer Team",
            "email": "support@istanbulairporttransfer.com"
        }
    ],
    "require": {
        "php": ">=8.0",
        "composer/installers": "^2.0",
        "ext-json": "*",
        "ext-mbstring": "*",
        "ext-openssl": "*"
    },
    "require-dev": {
        "phpunit/phpunit": "^9.5",
        "squizlabs/php_codesniffer": "^3.7",
        "wp-coding-standards/wpcs": "^3.0",
        "phpstan/phpstan": "^1.0"
    },
    "autoload": {
        "psr-4": {
            "IAT\\": "includes/"
        }
    },
    "autoload-dev": {
        "psr-4": {
            "IAT\\Tests\\": "tests/"
        }
    },
    "scripts": {
        "test": "phpunit",
        "test-coverage": "phpunit --coverage-html coverage",
        "cs": "phpcs",
        "cs-fix": "phpcbf",
        "stan": "phpstan analyse",
        "lint": "php -l",
        "security-check": "composer audit"
    },
    "config": {
        "allow-plugins": {
            "composer/installers": true
        }
    },
    "minimum-stability": "stable",
    "prefer-stable": true
}